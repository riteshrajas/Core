{
  "name": "ram",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "dev:interactive": "concurrently -k -n core,pipecat-server,pipecat-client -c cyan,green,magenta \"npm run dev\" \"npm run pipecat:server\" \"npm run pipecat:client\"",
    "start": "node dist/index.js",
    "cli": "tsx src/cli.ts",
    "init:one": "node scripts/init-one.mjs",
    "pipecat:server": "node scripts/pipecat-server.mjs",
    "pipecat:client": "npm --prefix pipecat-bot/client run dev",
    "pipecat:version": ".\\.venv-pipecat\\Scripts\\pipecat.exe --version",
    "pipecat:help": ".\\.venv-pipecat\\Scripts\\pipecat.exe --help",
    "pipecat:init:help": ".\\.venv-pipecat\\Scripts\\pipecat.exe init --help"
  },
  "dependencies": {
    "@langchain/community": "^0.2.0",
    "@langchain/core": "^0.2.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "dotenv": "^16.4.5",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "@types/express": "^5.0.0",
    "@types/node": "^20.12.7",
    "tsx": "^4.7.1",
    "typescript": "^5.4.5"
  }
}
