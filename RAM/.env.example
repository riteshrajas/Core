# AI provider routing defaults
# DEFAULT_AI_PROVIDER can be: ollama | openai | anthropic
DEFAULT_AI_PROVIDER=ollama
DEFAULT_AI_TEMPERATURE=0.2

# Optional high-level system prompt for Apex
SYSTEM_PROMPT=You are Apex, a practical multi-agent assistant.

# Ollama provider
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:4b

# OpenAI provider (optional)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Anthropic provider (optional)
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_MODEL=APEX-3-5-sonnet-latest
ANTHROPIC_MAX_TOKENS=1024

# Persistent memory storage path (JSON file)
APEX_MEMORY_FILE=.apex-memory.json

# MCP server settings (Streamable HTTP)
MCP_HOST=127.0.0.1
MCP_PORT=3000
# Optional comma-separated allowed hosts when binding to 0.0.0.0 or ::
MCP_ALLOWED_HOSTS=localhost,127.0.0.1

# Subagent defaults
SUBAGENT_MAX_STEPS=3
SUBAGENT_SYSTEM=You are a focused subagent. Provide concise progress notes and the best possible answer.

